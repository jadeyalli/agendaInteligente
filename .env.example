# ──────────────────────────────────────────────────────────────────────────────
# Agenda Inteligente — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# Desarrollo local (SQLite — provider = "sqlite" en schema.prisma):
DATABASE_URL="file:./prisma/dev.db"

# Producción (PostgreSQL — cambia provider a "postgresql" en schema.prisma):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
#
# Ejemplo con Supabase:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
#
# Ejemplo con Neon:
# DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]/[DATABASE]?sslmode=require"

# ── Python / Solver ───────────────────────────────────────────────────────────
# Ruta al ejecutable de Python con OR-Tools instalado.
# En desarrollo local suele ser "python" o "python3".
# En producción puede ser la ruta absoluta del entorno virtual:
#   /app/.venv/bin/python  (Linux)
#   C:\app\.venv\Scripts\python.exe  (Windows)
PYTHON_BIN="python"

# ── URL pública (usada en OG tags y meta) ────────────────────────────────────
# En producción pon la URL real de tu app (sin barra final).
NEXT_PUBLIC_APP_URL="https://agenda-inteligente.vercel.app"

# ── Sesión ────────────────────────────────────────────────────────────────────
# Entorno de ejecución (next.js lo detecta automáticamente, pero puedes forzarlo)
# NODE_ENV="production"
