{
  "name": "agenda-inteligente",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:migrate": "prisma migrate deploy || prisma db push",
    "db:prepare": "npm run db:migrate --silent && prisma generate",
    "db:reset": "npx tsx scripts/reset-db.ts",
    "db:seed-events": "npx tsx scripts/seed-events.ts",
    "db:seed-reminders": "npx tsx scripts/seed-reminders.ts",
    "db:seed-calendar": "npx tsx scripts/seed-calendar.ts",
    "db:seed": "npm run db:seed-events && npm run db:seed-reminders",
    "db:fresh": "npm run db:reset && npm run db:seed",
    "predev": "npm run db:prepare",
    "prestart": "npm run db:prepare",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "studio": "npm run db:prepare && prisma studio",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/interaction": "^6.1.19",
    "@fullcalendar/multimonth": "^6.1.19",
    "@fullcalendar/react": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@prisma/client": "^6.17.1",
    "framer-motion": "^12.23.24",
    "ical.js": "^2.2.1",
    "lucide-react": "^0.545.0",
    "next": "15.5.4",
    "node-ical": "^0.21.0",
    "prisma": "^6.17.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
