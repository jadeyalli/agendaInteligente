// =====================
// Datasource & Generator
// =====================
datasource db {
  // Para desarrollo local usa SQLite (DATABASE_URL="file:./dev.db").
  // Para producción cambia el provider a "postgresql" y apunta DATABASE_URL
  // a tu cadena de conexión PostgreSQL (ver .env.example).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =====================
// Enums — Core
// =====================
enum Priority {
  CRITICA
  URGENTE
  RELEVANTE
  OPCIONAL
  RECORDATORIO
}

enum RepeatRule {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum AvailabilityWindow {
  NONE
  PRONTO
  SEMANA
  MES
  RANGO
}

enum EventKind {
  EVENTO
  TAREA
  SOLICITUD
  RECORDATORIO
}

enum ICalStatus {
  TENTATIVE
  CONFIRMED
  CANCELLED
}

enum ICalTransparency {
  OPAQUE
  TRANSPARENT
}

enum ICalMethod {
  PUBLISH
  REQUEST
  REPLY
  CANCEL
  ADD
  REFRESH
  COUNTER
  DECLINECOUNTER
}

enum ICalTodoStatus {
  NEEDS_ACTION
  IN_PROCESS
  COMPLETED
  CANCELLED
}

// =====================
// Enums — Colaborativos
// =====================
enum CollabStatus {
  DRAFT
  VOTING
  CONFIRMED
  RENEGOTIATING
  CANCELLED
}

enum CollabRole {
  HOST
  ESSENTIAL
  REGULAR
}

enum ParticipantStatus {
  PENDING
  VOTED
  ACCEPTED
  DECLINED
  LEFT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// =====================
// Modelos — Core
// =====================
model User {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  name     String?

  // Relación 1:1 con Calendar (un solo calendario por usuario)
  calendar Calendar?

  events   Event[]
  slots        AvailabilitySlot[]
  settings     UserSettings?
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Calendar {
  id     String @id @default(cuid())
  // @unique garantiza la relación 1:1 con User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  name     String
  color    String?
  timezone String  @default("UTC")

  source CalendarSource?
  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarSource {
  id         String   @id @default(cuid())
  calendarId String   @unique
  calendar   Calendar @relation(fields: [calendarId], references: [id])

  kind       String
  url        String?
  etag       String?
  syncToken  String?
  lastSynced DateTime?
  method     ICalMethod?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id String @id @default(cuid())

  // Relaciones
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  calendarId String?
  calendar   Calendar? @relation(fields: [calendarId], references: [id])

  // Enlace maestro→instancias (para posicionamiento inteligente)
  originEventId String?
  originEvent   Event?  @relation("EventOrigin", fields: [originEventId], references: [id])
  instances     Event[] @relation("EventOrigin")

  // Básicos
  kind        EventKind @default(EVENTO)
  title       String
  description String?

  // Fecha/hora
  start           DateTime?
  end             DateTime?
  tzid            String?
  durationMinutes Int?

  // Tareas (VTODO)
  dueDate         DateTime?
  todoStatus      ICalTodoStatus?
  completed       Boolean         @default(false)
  completedAt     DateTime?
  percentComplete Int?

  // Clasificación UX
  priority Priority
  category String?

  // Comportamiento en agenda
  isInPerson               Boolean @default(true)
  canOverlap               Boolean @default(false)
  isAllDay                 Boolean @default(false)
  participatesInScheduling Boolean @default(true)

  // Recurrencia (iCal)
  repeat RepeatRule @default(NONE)
  rrule  String?
  rdate  Json?
  exrule String?
  exdate Json?

  // Ventanas de disponibilidad (heurísticas)
  window      AvailabilityWindow @default(NONE)
  windowStart DateTime?
  windowEnd   DateTime?

  // Estado interno
  isFixed Boolean @default(false)
  status  String  @default("SCHEDULED")

  // Metadatos iCal separados (relación 1:1 opcional)
  icalMeta EventICalMeta?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, start])
  @@index([calendarId, start])
  @@index([status])
  @@index([participatesInScheduling])
}

/// Metadatos de sincronización iCal separados del núcleo del evento.
/// Solo existe para eventos importados desde iCal o creados con campos iCal explícitos.
model EventICalMeta {
  id      String @id @default(cuid())
  eventId String @unique
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Almacenado para la restricción @@unique de sincronización iCal
  calendarId String?

  // Identidad iCal
  uid         String?
  sequence    Int     @default(0)
  etag        String?
  lastModified DateTime?
  createdIcal  DateTime?

  // Localización / estado iCal
  location     String?
  statusIcal   ICalStatus?
  transparency ICalTransparency?

  // Colaboración iCal
  organizer String?
  attendees Json?

  // VEVENT/VTODO original (para auditoría)
  icsRaw String?

  // Índice compuesto para deduplicación en sync iCal
  @@unique([calendarId, uid])
}

model AvailabilitySlot {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  dayOfWeek Int // 0=Dom ... 6=Sáb
  startTime String // "HH:mm"
  endTime   String // "HH:mm"

  @@index([userId, dayOfWeek])
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  dayStart    String @default("09:00")
  dayEnd      String @default("18:00")
  enabledDays String @default("[\"mon\",\"tue\",\"wed\",\"thu\",\"fri\"]")

  eventBufferMinutes    Int @default(0)
  schedulingLeadMinutes Int @default(0)
  timezone              String @default("America/Mexico_City")
  categories            String @default("[\"Escuela\",\"Trabajo\",\"Personal\",\"Familia\",\"Salud\"]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// Modelos — Colaborativos
// =====================

/// Evento colaborativo multiusuario con flujo de votación y confirmación.
model CollaborativeEvent {
  id          String      @id @default(cuid())
  hostUserId  String
  title       String
  description String?
  durationMin Int
  status      CollabStatus @default(DRAFT)

  /// Slot confirmado (nulo hasta la fase de confirmación)
  confirmedSlot DateTime?

  /// Zona horaria canónica del anfitrión (referencia para traducción)
  hostTimezone String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slots        CollabSlotOption[]
  participants CollabParticipant[]
  requests     CollabRescheduleRequest[]
}

/// Opción de horario propuesta para un evento colaborativo.
/// Los bloques fantasma de los slots no confirmados se eliminan al confirmar.
model CollabSlotOption {
  id             String @id @default(cuid())
  collabEventId  String
  collabEvent    CollaborativeEvent @relation(fields: [collabEventId], references: [id], onDelete: Cascade)

  proposedBy     String
  start          DateTime
  end            DateTime

  /// ID del PhantomBlock asociado en la agenda del anfitrión (null si no aplica)
  phantomBlockId String?

  votes       Int     @default(0)
  isConfirmed Boolean @default(false)

  /// Ronda de votación (1 = inicial, 2+ = renegociaciones)
  round Int @default(1)
}

/// Participante en un evento colaborativo con su rol y estado de participación.
model CollabParticipant {
  id            String @id @default(cuid())
  collabEventId String
  collabEvent   CollaborativeEvent @relation(fields: [collabEventId], references: [id], onDelete: Cascade)

  userId    String
  role      CollabRole
  status    ParticipantStatus @default(PENDING)

  /// Slot por el que votó (null si aún no ha votado)
  votedSlotId String?

  /// ID del evento en la agenda personal del invitado (null hasta aceptar)
  localEventId String?

  /// Zona horaria del invitado para mostrar horarios en formato dual
  timezone String

  @@index([collabEventId, userId])
}

/// Solicitud de reagendamiento iniciada por un invitado indispensable.
model CollabRescheduleRequest {
  id            String @id @default(cuid())
  collabEventId String
  collabEvent   CollaborativeEvent @relation(fields: [collabEventId], references: [id], onDelete: Cascade)

  requestedBy String
  status      RequestStatus @default(PENDING)

  createdAt DateTime @default(now())
}

/// Bloque temporal en la agenda del usuario que reserva capacidad durante la negociación
/// colaborativa o manualmente. Actúa como evento fijo en el solver (restricción R7).
model PhantomBlock {
  id            String   @id @default(cuid())
  userId        String
  collabEventId String?
  start         DateTime
  end           DateTime
  isActive      Boolean  @default(true)
  title         String?
  reason        String?

  @@index([userId, isActive])
}

model Reservation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String?
  description String?

  // Reservación puntual
  start       DateTime?
  end         DateTime?

  // Reservación recurrente (isRecurring=true)
  isRecurring Boolean  @default(false)
  dayOfWeek   Int?     // 0=Dom, 1=Lun … 6=Sáb
  startTime   String?  // "HH:MM"
  endTime     String?  // "HH:MM"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, isRecurring])
}
